{
  "_meta": {
    "vertical": "biblioteca_suscripcion",
    "descripcion": "Configuración de Vertical 1: plataformas de suscripción de libros (ej. Bukku, Escape a Pluton).",
    "version": "1.0"
  },
  "behavioral_features": [
    "libros_leidos_total",
